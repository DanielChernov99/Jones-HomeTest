{
  "name": "jones-hometest",
  "version": "1.0.0",
  "description": "Playwright automation project for Jones home assignment",
  "main": "index.js",
  "scripts": {
    "setup": "npm install && npx playwright install chromium",
    "test": "npm run test:smoke && npm run test:regression",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep-invert @smoke",
    "test:headed": "npm run test:smoke:headed && npm run test:regression:headed",
    "test:smoke:headed": "playwright test --grep @smoke --headed",
    "test:regression:headed": "playwright test --grep-invert @smoke --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DanielChernov99/Jones-HomeTest.git"
  },
  "keywords": [
    "playwright",
    "automation",
    "qa",
    "jones"
  ],
  "author": "Daniel Chernov",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/DanielChernov99/Jones-HomeTest/issues"
  },
  "homepage": "https://github.com/DanielChernov99/Jones-HomeTest#readme",
  "devDependencies": {
    "@playwright/test": "^1.61.0"
  }
}